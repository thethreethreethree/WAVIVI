# Copy to .env.local and fill in real values.
# All env access in the codebase routes through src/lib/env.ts — never
# read process.env directly elsewhere.

# --- Supabase ---------------------------------------------------------------
# Project URL and anon key: Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never expose to the client.
# Used by the admin dashboard aggregates + ingestion endpoints.
SUPABASE_SERVICE_ROLE_KEY=

# --- Site -------------------------------------------------------------------
# Local dev fallback. In production the canonical URL is wondavu.com and
# resolveSiteUrl() picks it up automatically when VERCEL_ENV=production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Susen (AI travel concierge) -------------------------------------------
# DeepSeek API key — required for /api/susen/respond to work. Without it
# the client falls through to the offline rule engine.
DEEPSEEK_API_KEY=
# Optional override. Defaults to "deepseek-chat" (cheap/fast). Set to
# "deepseek-reasoner" for the chain-of-thought variant.
SUSEN_MODEL=
# CSV of identities (emails / handles) whose Susen chats are captured as
# tuning notes + flagged for live OPERATOR GUIDANCE injection. Defaults
# to johnsyramos@gmail.com,@john,john if unset.
SUSEN_ADMINS=

# --- Cron + ingestion (optional) -------------------------------------------
# Bearer token Vercel Cron sends to /api/cron/scan. Leave blank to disable
# the check (open route — only safe in local dev).
CRON_SECRET=
# Bearer token the Partner Collection extension sends to
# /api/admin/stays/ingest. Leave blank to disable that endpoint entirely.
INGEST_TOKEN=

# --- Instagram proxy (optional) --------------------------------------------
# Cloudflare Worker that proxies public-profile fetches, since Vercel DC
# IPs get rate-limited / login-walled by IG. Leave blank in dev.
INSTAGRAM_PROXY_URL=
INSTAGRAM_PROXY_SECRET=

# --- Wondavu Pet (in development) ------------------------------------------
# Gate for the Tamagotchi-style travel pet. Set to 1 only in dev / staging.
# When unset or anything else, /pet returns 404 and reward hooks no-op.
NEXT_PUBLIC_PET_ENABLED=
